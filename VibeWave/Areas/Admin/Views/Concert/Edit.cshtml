@using VibeWave.Models
@model Concert
<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class=" col text-center">
                <h2 class="text-white py-2">Edit Concert</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" asp-action="Edit">
            <input asp-for="Id" hidden />
            <div class="border p-3 mt-4">
                @*<div asp-validation-summary="All"></div>*@
                <div class="py-2 col-12">
                    <label asp-for="ConcertName" class="ms-2"> </label>
                    <input asp-for="ConcertName" class="form-control border-0 shadow" />
                    <span asp-validation-for="ConcertName" class="text-danger"></span>
                <div class="py-2 col-12">
                    <label asp-for="ActorName" class="ms-2"> </label>
                    <input asp-for="ActorName" class="form-control border-0 shadow" />
                    <span asp-validation-for="ActorName" class="text-danger"></span>
                </div>
                </div>
                @* <div class="py-2 col-12">
                    <label asp-for="ConcertCategory" class="ms-2"> </label>
                    <input asp-for="ConcertCategory" class="form-control border-0 shadow" />
                    <span asp-validation-for="ConcertCategory" class="text-danger"></span>
                </div> *@
                <div class="py-2 col-12">
                    <label asp-for="ConcertLocation" class="ms-2"> </label>
                    <input asp-for="ConcertLocation" class="form-control border-0 shadow" />
                    <span asp-validation-for="ConcertLocation" class="text-danger"></span>
                </div>
                <div class="py-2 col-12">
                    <label asp-for="DisplayDate" class="ms-2"> </label>
                    <input asp-for="DisplayDate" class="form-control border-0 shadow" />
                    <span asp-validation-for="DisplayDate" class="text-danger"></span>
                </div>
                <div class="py-2 col-12">
                    <label asp-for="DisplayTime" class="ms-2"> </label>
                    <input asp-for="DisplayTime" class="form-control border-0 shadow" />
                    <span asp-validation-for="DisplayTime" class="text-danger"></span>
                </div>
                <div class="py-2 col-12">
                    <label asp-for="TicketPrice" class="ms-2"> </label>
                    <input asp-for="TicketPrice" class="form-control border-0 shadow" />
                    <span asp-validation-for="TicketPrice" class="text-danger"></span>
                </div>
                <div class="py-2 col-12">
                    <label asp-for="CategoryId" class="ms-2"> </label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-control border-0 shadow">
                        <option disabled>--Select Category</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="row mt-3">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Update</button>
                    </div>

                    <div class="col-6 col-md-3">
                        <a asp-controller="Concert" asp-action="Index" class="btn btn-secondary border form-control">
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}
