@model VibeWave.Models.ChatInput
@{
    ViewData["Title"] = "Chat with VibeWave Bot";
}
@* <div class="card shadow border-0 mt-4">无边框、带阴影、顶部留白 
    <div class="card-header bg-secondary bg-gradient m-lg-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Contact Us</h2>
            </div>
        </div>
    </div> *@
@* <div class="card-body p-4"> *@
<div class="container" style="border-radius:5px; background:#f2f2f2; padding:20px;margin-top:20px;">
    <h2 class="mb-4">ChatBot</h2>
    <form method="post" class="row">
        <div>
            <label for="UserMessage">Your Message</label>
            <input asp-for="UserMessage" type="text" class="form-control" placeholder="Type your question here..." />
            <span asp-validation-for="UserMessage" class="text-danger"></span>

            <div style="margin-top:20px;">
                <input type="submit" value="Send" class="btn" style="background-color:#04AA6D; color:white; padding:12px 20px; border:none; border-radius:4px;" />
            </div>

            @* 显示机器人回复（从 ViewBag.Response 读取，由控制器 GET 方法设置）from AI *@
            @if (ViewBag.Response != null)
            {
                <div style="margin-top:30px; padding:15px; background-color:#e9ecef; border-radius:5px;">
                    <strong>Bot:</strong> @ViewBag.Response
                </div>
            }     
        </div>
    </form>
</div>
<style>
    body {
        font-family: Arial, Helvetica, sans-serif;
    }

    * {
        box-sizing: border-box;
    }

    input[type=text], select, textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
        margin-top: 6px;
        margin-bottom: 16px;
        resize: vertical;
    }

    input[type=submit] {
        background-color: #04AA6D;
        color: white;
        padding: 12px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }

        input[type=submit]:hover {
            background-color: #45a049;
        }

    .container {
        border-radius: 5px;
        background-color: #f2f2f2;
        padding: 20px;
    }
    /* 让submit按钮另起一行 */
    .text-danger {
        display: block;
        margin-bottom: 10px;
    }
</style>
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}

