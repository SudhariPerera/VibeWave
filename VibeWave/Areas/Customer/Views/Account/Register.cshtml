@using Microsoft.AspNetCore.Identity
@model VibeWave.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient m-lg-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Register</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" class="row">
            <div class="border p-3">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3 row p-1">
                    <label asp-for="Email" class="ms-2"></label>
                    <input asp-for="Email" class="form-control border-0 shadow"></input>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3 row p-1">
                    <label asp-for="Password" class="ms-2"></label>
                    <input asp-for="Password" class="form-control border-0 shadow"></input>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3 row p-1">
                    <label asp-for="ConfirmPassword" class="ms-2"></label>
                    <input asp-for="ConfirmPassword" class="form-control border-0 shadow"></input>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="mb-3 row p-1">
                    <label asp-for="PhoneNumber" class="ms-2"></label>
                    <input asp-for="PhoneNumber" class="form-control border-0 shadow" placeholder="(optional)"></input>
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="row pt-2">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Register</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-action="Login" class="btn btn-primary form-control">Already have an account?</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}