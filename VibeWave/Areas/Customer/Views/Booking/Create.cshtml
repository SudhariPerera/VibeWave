@using VibeWave.Models
@model Concert

@{
    ViewData["Title"] = "Book Concert";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3>Book Tickets</h3>
                </div>
                <div class="card-body">
                    <h4>@Model.ConcertName</h4>
                    <p><strong>Actor :</strong> @Model.ActorName</p>
                    <p><strong>Date :</strong> @Model.DisplayDate</p>
                    <p><strong>Time :</strong> @Model.DisplayTime</p>
                    <p><strong>Location :</strong> @Model.ConcertLocation</p>
                    <p><strong>Price :</strong> NZ$ @Model.TicketPrice</p>

                    <hr />

                    <form method="post" action="/Booking/Create">
                        <div class="form-group mb-3">
                            <label>Your Name</label>
                            <input type="text" name="CustomerName" class="form-control" required />
                        </div>

                        <div class="form-group mb-3">
                            <label>Email Address</label>
                            <input type="email" name="Email" class="form-control" required />
                        </div>

                        <div class="form-group mb-3">
                            <label>Number of Tickets</label>
                            <input type="number" name="NumberOfTickets" class="form-control" min="1" max="10" required />
                        </div>

                        <div class="form-group mb-3">
                            <label>Total Price (NZ$) </label>
                            <input type="text" id="totalPrice" class="form-control" readonly />
                        </div>

                        <input type="hidden" name="ConcertId" value="@Model.Id" />

                        <button type="submit" class="btn btn-success">Confirm Booking</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    const ticketPrice = parseFloat("@Model.TicketPrice");

    const ticketInput = document.querySelector('input[name="NumberOfTickets"]');
    const totalPriceField = document.getElementById("totalPrice");

    ticketInput.addEventListener("input", function () {
        let quantity = parseInt(this.value) || 0;
        let total = quantity * ticketPrice;
        totalPriceField.value = "NZ$ " + total;
    });
</script>