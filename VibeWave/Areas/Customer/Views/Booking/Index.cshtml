@using VibeWave.Models
@model List<Booking>

<h2>Booking List</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Concert</th>
            <th>Customer</th>
            <th>Email</th>
            <th>Qty</th>
            <th>Date</th>
            <th>Total Price</th>
            <th>QR Code</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.Concert?.ConcertName</td>
                <td>@booking.CustomerName</td>
                <td>@booking.Email</td>
                <td>@booking.NumberOfTickets</td>
                <td>@booking.BookingDate.ToString("dd MMM yyyy")</td>
                <td>@booking.TotalPrice</td>
                <td>
                    @if (!string.IsNullOrEmpty(booking.QrCodeUrl))
                    {
                        <img src="@booking.QrCodeUrl" style="width:80px;height:80px;" />
                    }
                </td>
                <td>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Booking" asp-action="BookingDetails" asp-route-id="@booking.Id" class="btn btn-primary mx-2">
                            <i class="bi bi-aspect-ratio"></i>
                        </a>

                        <a asp-controller="Booking" asp-action="Delete" asp-route-id="@booking.Id" class="btn btn-danger mx-2">
                            <i class="bi bi-trash-fill"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>