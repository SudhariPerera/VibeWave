@model Concert
<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class=" col text-center">
                <h2 class="text-white py-2">Delete Concert</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post">
            <input asp-for="Id" hidden />
            <div class="border p-3 mt-4">
                @*<div asp-validation-summary="All"></div>*@
                <div class="py-2 col-12">
                    <label asp-for="ConcertName" class="ms-2"> </label>
                    <input asp-for="ConcertName" disabled class="form-control" />
                </div>
                <div class="py-2 col-12">
                    <label asp-for="ConcertCategory" class="ms-2"> </label>
                    <input asp-for="ConcertCategory" disabled class="form-control" />
                </div>
                <div class="py-2 col-12">
                    <label asp-for="DisplayOrder" class="ms-2"> </label>
                    <input asp-for="DisplayOrder" disabled class="form-control" />
                </div>

                <div class="row mt-3">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Delete</button>
                    </div>

                    <div class="col-6 col-md-3">
                        <a asp-controller="Concert" asp-action="Index" class="btn btn-secondary border form-control">
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}
