@using VibeWave.Models
@model List<Category>

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary py-2"> Category List </h2>
        </div>
        <div class="col-6 text-solid">
            <a asp-controller="Category" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Category
            </a>
        </div>
    </div>

<table class="table table-bordered table-stried">
    <thread>
        <tr>
            <th>
                CategoryId
            </th>
            <th>
                Name
            </th>
            <th></th>
        </tr>
    </thread>
    <tbody>
            @foreach (var obj in Model)
        {
            <tr>
                <td>@obj.CategoryId</td>
                <td>@obj.Name</td>

                <td>
                    <div class="w-75 btn-group" role="group">
                        <a asp-controller="Category" asp-action="Edit" asp-route-id="@obj.CategoryId" class="btn btn-primary mx-2">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        <a asp-controller="Category" asp-action="Delete" asp-route-id="@obj.CategoryId" class="btn btn-danger mx-2">
                            <i class="bi bi-trash-fill"></i>
                        </a>
                    </div>
                </td>
            </tr>
         }
    </tbody>
</table>
</div>